# ============================================================
# FINANCE DATA PLATFORM — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# ── Stripe ──────────────────────────────
STRIPE_API_KEY=<your-stripe-test-api-key>

# ── Azure Storage (ADLS Gen2) ───────────
AZURE_STORAGE_ACCOUNT=stfindatalakedev001
AZURE_STORAGE_KEY=<your-storage-account-key>
AZURE_CONTAINER=finance
AZURE_TENANT_ID=<your-azure-tenant-id>
AZURE_SUBSCRIPTION_ID=<your-azure-subscription-id>
AZURE_RESOURCE_GROUP=rg-finance-data-platform-dev

# ── Snowflake ───────────────────────────
SNOWFLAKE_ACCOUNT=<your-snowflake-account>   # e.g. xy12345.us-east-1
SNOWFLAKE_USER=FINANCE_AIRFLOW_USER
SNOWFLAKE_PASSWORD=ChangeMe_airflow_2024!
SNOWFLAKE_ROLE=FINANCE_TRANSFORMER
SNOWFLAKE_WAREHOUSE=FINANCE_TRANSFORM_WH
SNOWFLAKE_DATABASE=FINANCE_PLATFORM_DEV
SNOWFLAKE_SCHEMA=RAW

# ── dbt (Snowflake) ─────────────────────
DBT_SNOWFLAKE_ACCOUNT=<your-snowflake-account>
DBT_SNOWFLAKE_USER=FINANCE_DBT_USER
DBT_SNOWFLAKE_PASSWORD=ChangeMe_dbt_2024!
DBT_SNOWFLAKE_ROLE=FINANCE_TRANSFORMER
DBT_SNOWFLAKE_WAREHOUSE=FINANCE_TRANSFORM_WH
DBT_SNOWFLAKE_DATABASE=FINANCE_PLATFORM_DEV
DBT_SNOWFLAKE_SCHEMA=BRONZE

# ── Airflow ──────────────────────────────
AIRFLOW_UID=50000
AIRFLOW__CORE__FERNET_KEY=<generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())">
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__WEBSERVER__SECRET_KEY=<random-string>

# ── Slack Notifications (optional) ───────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXX/YYYY/ZZZZ
